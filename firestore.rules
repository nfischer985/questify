rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Validate that a string field exists, is a string, and fits within a length.
    function isStr(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    // Validate a non-negative integer within an inclusive upper bound.
    function isNatInt(value, maxVal) {
      return value is int && value >= 0 && value <= maxVal;
    }

    // ── /users/{username} ─────────────────────────────────────────────────────
    // Public read so friend-search works. Only the owner can create their doc.
    // Usernames are permanent — no updates or deletes allowed.
    match /users/{username} {
      allow read:  if isAuthed();
      allow create: if isOwner(request.resource.data.uid)
        && request.resource.data.uid     == request.auth.uid
        && isStr(request.resource.data.username, 24)
        && request.resource.data.username.matches('^[a-z0-9_\\-]+$')
        && isStr(request.resource.data.displayName, 64);
      allow update, delete: if false; // usernames are immutable
    }

    // ── /usersByUid/{uid} ─────────────────────────────────────────────────────
    // Mirror of /users — same rules, keyed by UID instead of username.
    match /usersByUid/{uid} {
      allow read:  if isAuthed();
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid;
      allow update, delete: if false;
    }

    // ── /leaderboard/{uid} ────────────────────────────────────────────────────
    // Any authenticated user can read rankings.
    // Users may only write their own entry, and values must be in sane ranges
    // to prevent score injection.
    match /leaderboard/{uid} {
      allow read: if isAuthed();
      allow write: if isOwner(uid)
        && request.resource.data.uid     == uid
        && isStr(request.resource.data.username, 24)
        && isStr(request.resource.data.displayName, 64)
        && isNatInt(request.resource.data.level,                 10000)
        && isNatInt(request.resource.data.xp,                    1000000000)
        && isNatInt(request.resource.data.totalXp,               1000000000)
        && isNatInt(request.resource.data.coins,                 10000000)
        && isNatInt(request.resource.data.streak,                100000)
        && isNatInt(request.resource.data.questsCompleted,       1000000)
        && isNatInt(request.resource.data.weeklyQuestsCompleted, 10000)
        && request.resource.data.premium is bool;
    }

    // ── /userActivity/{uid} ───────────────────────────────────────────────────
    // Friends' activity feeds are readable by any authenticated user
    // (needed for the real-time activity ticker). Only the owner may write.
    match /userActivity/{uid} {
      allow read:  if isAuthed();
      allow write: if isOwner(uid);
    }

    // ── /partyChat/{partyCode}/messages/{messageId} ───────────────────────────
    // Any authenticated user can read party chat.
    // Users can only create messages (not edit/delete) and must sign them
    // with their own UID. Text is capped at 500 characters.
    match /partyChat/{partyCode}/messages/{messageId} {
      allow read:   if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.uid      == request.auth.uid
        && isStr(request.resource.data.text, 500)
        && request.resource.data.createdAt is int
        && partyCode.size() == 6
        && partyCode.matches('^[A-Z0-9]+$');
      allow update, delete: if false; // messages are immutable
    }

    // ── /parties/{partyCode} ─────────────────────────────────────────────────
    // Party metadata (name, members) is readable and writable by any
    // authenticated user — membership checks happen client-side.
    match /parties/{partyCode} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && partyCode.size() == 6;
    }

    // ── Catch-all: deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
